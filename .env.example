# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# OpenAI (required — used by /api/plan, /api/patch, /api/packing)
OPENAI_API_KEY=sk-...

# GitHub (required — stores trip plans as secret Gists)
GITHUB_TOKEN=ghp_...

# Stripe (required for Pro billing; endpoints return 503 without these)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...

# Web Push / VAPID (required for push notifications)
VAPID_PUBLIC_KEY=BN...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:hello@tripva.app
PUSH_CRON_TOKEN=...

# Admin dashboard
ADMIN_TOKEN=...

# CORS (defaults to https://tripva.app if omitted)
ALLOWED_ORIGIN=https://tripva.app
