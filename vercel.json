{
  "version": 2,
  "functions": {
    "api/plan.js": { "maxDuration": 300 },
    "api/patch.js": { "maxDuration": 300 },
    "api/save.js":  { "maxDuration": 30 },
    "api/trip.js":  { "maxDuration": 30 },
    "api/health.js":{ "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
