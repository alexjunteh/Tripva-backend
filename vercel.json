{
  "version": 2,
  "functions": {
    "api/plan.js": {
      "maxDuration": 300
    },
    "api/patch.js": {
      "maxDuration": 300
    },
    "api/save.js": {
      "maxDuration": 30
    },
    "api/trip.js": {
      "maxDuration": 30
    },
    "api/health.js": {
      "maxDuration": 10
    },
    "api/stats.js": {
      "maxDuration": 15
    },
    "api/user.js": {
      "maxDuration": 15
    },
    "api/packing.js": {
      "maxDuration": 60
    },
    "api/admin.js": {
      "maxDuration": 30
    },
    "api/stripe.js": {
      "maxDuration": 30
    },
    "api/push.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/user/magic-link",
      "destination": "/api/user"
    },
    {
      "source": "/api/user/oauth",
      "destination": "/api/user"
    },
    {
      "source": "/api/admin/analytics",
      "destination": "/api/admin"
    },
    {
      "source": "/api/stripe/checkout",
      "destination": "/api/stripe"
    },
    {
      "source": "/api/stripe/portal",
      "destination": "/api/stripe"
    },
    {
      "source": "/api/stripe/webhook",
      "destination": "/api/stripe"
    },
    {
      "source": "/api/push/public-key",
      "destination": "/api/push"
    },
    {
      "source": "/api/push/subscribe",
      "destination": "/api/push"
    },
    {
      "source": "/api/push/unsubscribe",
      "destination": "/api/push"
    },
    {
      "source": "/api/push/send-daily",
      "destination": "/api/push"
    },
    {
      "source": "/api/user/verify",
      "destination": "/api/user"
    },
    {
      "source": "/api/user/signup",
      "destination": "/api/user"
    },
    {
      "source": "/api/user/signin",
      "destination": "/api/user"
    },
    {
      "source": "/api/user/reset-password",
      "destination": "/api/user"
    },
    {
      "source": "/api/user/me",
      "destination": "/api/user"
    },
    {
      "source": "/api/user/trips/save",
      "destination": "/api/user"
    },
    {
      "source": "/api/user/trips/:id",
      "destination": "/api/user"
    },
    {
      "source": "/api/user/trips",
      "destination": "/api/user"
    }
  ],
  "crons": [
    {
      "path": "/api/push/send-daily?cron=1",
      "schedule": "0 13 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}